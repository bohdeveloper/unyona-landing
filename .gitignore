# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/frontend/node_modules
/backend/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/out/

# next.js
frontend/.next/
frontend/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
frontend/.env.local
frontend/.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code (configuración local del entorno de desarrollo)
.claude/

# codebase-memory-mcp: snapshot local del grafo. Es un artefacto derivado que el
# watcher regenera en cada cambio (graba el hash de HEAD, así que nunca queda limpio).
# Se versionan .mcp.json y graph.html; el índice se reconstruye en segundos.
.codebase-memory/artifact.json
.codebase-memory/graph.db.zst
